---
import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="About | Manuel Gorrin" description="About Manuel Gorrin">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About Me"
				tagline="Learn more about my background, skills, and what drives me as a developer."
				align="center"
			/>
			
			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						My name is Manuel, I'm passionate about programming, I enjoy learning new technologies, 
						and I'm currently learning full-stack web development. I currently specialize in backend development. 
						I'm proficient in several programming languages, following best practices, object-oriented programming, data structures, and design patterns.
						I also have extensive knowledge in DevOps, network administration, and security analysis.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p>Computer Engineering at the University of Matanzas, Cuba.</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<div class="skills-grid">
						<div class="skill-category">
							<span class="category-label">Languages</span>
							<div class="tech-pills">
								<span class="tech-pill">Python</span>
								<span class="tech-pill">JavaScript</span>
								<span class="tech-pill">C#</span>
								<span class="tech-pill">PHP</span>
								<span class="tech-pill">Bash</span>
							</div>
						</div>
						<div class="skill-category">
							<span class="category-label">Frontend</span>
							<div class="tech-pills">
								<span class="tech-pill">React</span>
								<span class="tech-pill">Next.js</span>
								<span class="tech-pill">TailwindCSS</span>
								<span class="tech-pill">HTML5</span>
								<span class="tech-pill">CSS3</span>
							</div>
						</div>
						<div class="skill-category">
							<span class="category-label">Backend</span>
							<div class="tech-pills">
								<span class="tech-pill">Node.js</span>
								<span class="tech-pill">Express.js</span>
								<span class="tech-pill">NestJS</span>
								<span class="tech-pill">ASP.NET</span>
								<span class="tech-pill">Flask</span>
								<span class="tech-pill">FastAPI</span>
							</div>
						</div>
						<div class="skill-category">
							<span class="category-label">Databases</span>
							<div class="tech-pills">
								<span class="tech-pill">PostgreSQL</span>
								<span class="tech-pill">MySQL</span>
								<span class="tech-pill">MariaDB</span>
								<span class="tech-pill">MongoDB</span>
								<span class="tech-pill">SQLite</span>
								<span class="tech-pill">Redis</span>
								<span class="tech-pill">InfluxDB</span>
							</div>
						</div>
						<div class="skill-category">
							<span class="category-label">DevOps &amp; Cloud</span>
							<div class="tech-pills">
								<span class="tech-pill">Docker</span>
								<span class="tech-pill">Kubernetes</span>
								<span class="tech-pill">AWS</span>
								<span class="tech-pill">Terraform</span>
								<span class="tech-pill">Ansible</span>
								<span class="tech-pill">GitHub Actions</span>
								<span class="tech-pill">Jenkins</span>
								<span class="tech-pill">DigitalOcean</span>
							</div>
						</div>
						<div class="skill-category">
							<span class="category-label">APIs &amp; Tools</span>
							<div class="tech-pills">
								<span class="tech-pill">GraphQL</span>
								<span class="tech-pill">Kafka</span>
								<span class="tech-pill">JWT</span>
								<span class="tech-pill">MinIO</span>
								<span class="tech-pill">Prisma</span>
								<span class="tech-pill">Git</span>
								<span class="tech-pill">Nginx</span>
								<span class="tech-pill">Apache</span>
							</div>
						</div>
					</div>
				</div>
			</section>
			<section>
				<h2 class="section-title">Focus</h2>
				<div class="content">
					<p>I care deeply about software optimization, security, best practices, and code quality. I believe in writing efficient, secure, and maintainable code that follows industry standards.</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-lg);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		color: var(--gray-200);
		padding: 1.5rem;
		border-radius: var(--radius-lg);
		border: 1px solid transparent;
		transition: all var(--hover-transition);
	}

	section:hover {
		border-color: var(--glass-border);
		background: var(--accent-subtle-overlay);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
		background: var(--gradient-hero);
		background-size: 200% auto;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.content {
		grid-column: 2 / 4;
		line-height: 1.7;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	/* ── Skills grid ── */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 1rem;
		margin-top: 0.25rem;
	}

	.skill-category {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1rem 1.125rem;
		border-radius: var(--radius-lg);
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		backdrop-filter: blur(var(--glass-blur));
		transition: all var(--hover-transition);
	}

	.skill-category:hover {
		border-color: var(--accent-regular);
		box-shadow: var(--shadow-glow);
		transform: translateY(-2px);
	}

	.category-label {
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		background: var(--gradient-accent-orange);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.tech-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.tech-pill {
		font-size: 0.72rem;
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		background: var(--accent-subtle-overlay);
		border: 1px solid var(--glass-border);
		color: var(--gray-200);
		transition: all var(--hover-transition);
		white-space: nowrap;
	}

	.tech-pill:hover {
		background: var(--accent-overlay);
		border-color: var(--accent-regular);
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}

		section:hover {
			border-color: transparent;
			background: transparent;
		}
	}
</style>
